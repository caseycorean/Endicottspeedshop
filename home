<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">

<title>Endicott Speed Shop</title>

<style>
:root {
    --bg: #f5f5f5;
    --text: #111;
    --muted: #666;
    --accent: #000;
}

/* RESET */
* {
    margin: 0;
    padding: 0;
    box-sizing: border-box;
}

/* BASE */
body {
    font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, sans-serif;
    background: var(--bg);
    color: var(--text);
    line-height: 1.5;
}

/* BACKGROUND LOGO */
.background-logo {
    position: fixed;
    top: 10%;
    left: 50%;
    transform: translateX(-50%);
    width: 1200px;
    opacity: 0.04;
    z-index: 0;
    pointer-events: none;
}

/* HEADER */
.header {
    position: sticky;
    top: 0;
    background: rgba(245,245,245,0.85);
    backdrop-filter: blur(10px);
    padding: 16px 20px;
    z-index: 10;
    display: flex;
    justify-content: space-between;
    align-items: center;
}

.logo-text {
    font-weight: 600;
    letter-spacing: 0.08em;
    font-size: 14px;
}

.connect-btn {
    border: 1px solid #000;
    padding: 8px 14px;
    font-size: 12px;
    text-transform: uppercase;
    cursor: pointer;
}

/* HERO */
.hero {
    padding: 80px 20px 60px;
    max-width: 900px;
    margin: auto;
    position: relative;
    z-index: 1;
}

.hero h1 {
    font-size: 32px;
    font-weight: 600;
    margin-bottom: 12px;
}

.hero p {
    color: var(--muted);
    font-size: 15px;
}

/* GRID SECTIONS */
.section {
    max-width: 1000px;
    margin: 40px auto;
    padding: 0 20px;
    position: relative;
    z-index: 1;
}

/* CARD SYSTEM */
.card {
    background: rgba(255,255,255,0.75);
    backdrop-filter: blur(6px);
    border: 1px solid rgba(0,0,0,0.08);
    padding: 20px;
    margin-bottom: 20px;
}

/* LABELS (engineering feel) */
.label {
    font-size: 11px;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--muted);
    margin-bottom: 8px;
}

/* CALCULATOR LINK */
.calculator-link {
    display: inline-block;
    margin-top: 12px;
    font-size: 13px;
    border-bottom: 1px solid #000;
    cursor: pointer;
}

/* FOOTER */
.footer {
    text-align: center;
    padding: 60px 20px;
    color: var(--muted);
    font-size: 12px;
}

/* MOBILE */
@media (max-width: 768px) {
    .background-logo {
        width: 700px;
        top: 20%;
        opacity: 0.05;
    }

    .hero h1 {
        font-size: 26px;
    }
}
</style>
</head>

<body>

<!-- BACKGROUND LOGO -->
<img src="logo-round.png" class="background-logo">

<!-- HEADER -->
<div class="header">
    <div class="logo-text">ENDICOTT SPEED SHOP</div>
    <div class="connect-btn">Connect</div>
</div>

<!-- HERO -->
<div class="hero">
    <h1>Measure. Test. Improve.</h1>
    <p>
        Tools, data, and real-world builds focused on understanding performance—
        not guessing at it.
    </p>
</div>

<!-- SECTION: CALCULATOR -->
<div class="section">

    <div class="card">
        <div class="label">Tool</div>
        <h2>Weight Balance Calculator</h2>
        <p>
            Model how component changes affect total weight and front/rear distribution.
            Built for real-world decisions.
        </p>

        <a href="index.html" class="calculator-link">
            Open Calculator →
        </a>
    </div>

</div>

<!-- SECTION: FUTURE CONTENT -->
<div class="section">

    <div class="card">
        <div class="label">In Development</div>
        <h2>Guides & Articles</h2>
        <p>
            Suspension geometry, weight transfer, packaging constraints, and real build data.
            Structured for clarity, not noise.
        </p>
    </div>

    <div class="card">
        <div class="label">Coming Soon</div>
        <h2>Concept Rendering Feedback</h2>
        <p>
            Compare design directions and vote on future builds. Input drives decisions.
        </p>
    </div>

</div>

<!-- FOOTER -->
<div class="footer">
    Endicott Speed Shop — Built, not theorized
</div>

</body>
</html>
